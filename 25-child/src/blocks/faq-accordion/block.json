{
    "$schema": "https://schemas.wp.org",
    "apiVersion": 3,
    "name": "fz/faq-accordion",
    "title": "FAQ Accordion",
    "category": "text",
    "icon": "editor-ul",
    "attributes": {
        "heading": {
            "type": "string",
            "source": "html",
            "selector": "h2",
            "default": "Frequently Asked Questions"
        }
    },
    "supports": {
        "html": false,
        "anchor": true
    },
    "editorScript": "file:./index.js",
    "viewScript": "file:./view.js",
    "style": "file:./style-index.css"
}